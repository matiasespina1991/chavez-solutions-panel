// Firestore Security Rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthorized() {
      return request.auth != null;
    }

    // Requests (configurador)
    match /requests/{requestId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized();
      allow delete: if false;
    }

    // Archived deleted requests (backend only)
    match /deleted_requests/{requestId} {
      allow read, create, update, delete: if false;
    }

    // Work Orders (created/managed from backend callable)
    match /work_orders/{workOrderId} {
      allow read: if isAuthorized();
      allow create, update, delete: if false;
    }

    // Services catalog (frontend read-only, admin writes via callable)
    match /services/{serviceId} {
      allow read: if isAuthorized();
      allow create, update, delete: if false;
    }

    // Clients master data (frontend read-only, writes via callable)
    match /clients/{clientId} {
      allow read: if isAuthorized();
      allow create, update, delete: if false;
    }

    // Auth bootstrap config (authorized users list)
    match /config/{configId} {
      allow read: if isAuthorized();
      allow create, update, delete: if false;
    }

    // Mail outbox (backend only)
    match /mail_outbox/{mailId} {
      allow read, create, update, delete: if false;
    }

    // Assets collection
    match /assets/{mediaId} {
      allow read: if isAuthorized();
      // Frontend cannot write assets. Cloud Functions (Admin SDK) bypass rules.
      allow write: if false;
    }

    // MediaSets collection
    match /mediasets/{setId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();

      // Items subcollection
      match /items/{itemId} {
        allow read: if isAuthorized();
        allow create, update, delete: if isAuthorized();
      }
    }

    // Exhibitions collection (admin UI legacy)
    match /exhibitions/{exhibitionId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();
    }

    // Media collection (admin UI legacy)
    match /media/{mediaId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();
    }

    // About Me (admin UI legacy)
    match /about_me/{docId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();
    }

    // Contact (admin UI legacy)
    match /contact/{docId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();
    }

    // About Me + Contact collection (admin UI legacy)
    match /about_me_contact/{docId} {
      allow read: if isAuthorized();
      allow create, update, delete: if isAuthorized();
    }

    // Prevent direct frontend creation of subcollections (except mediasets/items which is handled above)
    match /assets/{mediaId}/{sub=**} {
      allow write: if false;
    }

    // Default deny for every non-explicit collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
